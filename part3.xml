 function xmli_check_1($data)
{

    // str_replace()을 이용하여 특수문자(기호)들을 이스케프를 실시한다.
    // str_replace(A, B, C) : C 문자열에서 A 문자열을 B 문자열로 치환 시킴
    // Replaces dangerous characters: ( ) = ' [ ] : , * / WHITESPACE
  
    $input = str_replace("(", "", $data);   
    $input = str_replace(")", "", $input);
    $input = str_replace("=", "", $input);
    $input = str_replace("'", "", $input);
    $input = str_replace("[", "", $input);
    $input = str_replace("]", "", $input);
    $input = str_replace(":", "", $input);
    $input = str_replace(",", "", $input);
    $input = str_replace("*", "", $input);
    $input = str_replace("/", "", $input);
    $input = str_replace(" ", "", $input);

 
    return $input;
}
